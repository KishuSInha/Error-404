{
  "name": "metrixa-ai",
  "version": "0.1.1",
  "productName": "Metrixa AI",
  "description": "AI-powered screen analysis assistant for macOS",
  "homepage": "https://metrixaai.site",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "keywords": [
    "ai",
    "screen-capture",
    "productivity",
    "macos"
  ],
  "author": "MetrixaAI",
  "license": "MIT",
  "dependencies": {
    "active-win": "^8.2.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.6.1",
    "electron-store": "^8.2.0",
    "node-fetch": "^3.3.2",
    "node-schedule": "^2.1.1",
    "playwright": "^1.57.0",
    "screenshot-desktop": "^1.15.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.metrixa.desktop",
    "productName": "Metrixa AI",
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
