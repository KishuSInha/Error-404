{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "noEmit": true
  },
  "include": ["src/**/*.js", "electron/**/*.cjs", "scripts/**/*.mjs"],
  "exclude": ["node_modules", "dist", "electron/**/*.html"]
}
